# Copy this file to .env and fill in your own values.
# Nothing in this repo will run against real data without these set.

# HubSpot private app access token. Create one under
# Settings > Integrations > Private Apps in your HubSpot account.
HUBSPOT_ACCESS_TOKEN=

# The custom object type ID this sync targets. Defaults to a placeholder
# if not set. Find your object type ID under Settings > Data Management
# > Objects in HubSpot, or via the CRM object schemas API.
HUBSPOT_OBJECT_TYPE=2-SYNC_OBJECT_ID

# Airtable personal access token. Create one at airtable.com/create/tokens
# with data.records:read and data.records:write scopes on the target base.
AIRTABLE_API_KEY=

# The base ID for the Airtable base you are syncing against.
# Found in the base's API documentation page, or in its URL.
AIRTABLE_BASE_ID=

# The table name within that base. Defaults to "Sync Records" if not set.
AIRTABLE_TABLE_NAME=Sync Records

# Milliseconds to wait between Airtable writes during a sync run, to stay
# under Airtable's 5 requests/second per-base limit. Defaults to 210ms.
# Test suites override this to 0 since they never hit a real API.
AIRTABLE_PACE_MS=210
